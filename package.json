{
  "name": "@0x-wim/mcp-oauth",
  "version": "0.1.0",
  "description": "Platform-independent OAuth 2.1 authorization provider",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/oauth-provider.js",
      "types": "./dist/oauth-provider.d.ts"
    },
    "./next": {
      "import": "./dist/next.js",
      "types": "./dist/next.d.ts"
    },
    "./oidc": {
      "import": "./dist/oidc/index.js",
      "types": "./dist/oidc/index.d.ts"
    }
  },
  "main": "dist/oauth-provider.js",
  "types": "dist/oauth-provider.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "check": "npm run typecheck && npm run test",
    "typecheck": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prettier": "prettier -w .",
    "prepublishOnly": "npm run build"
  },
  "author": "Kenton Varda <kenton@cloudflare.com>",
  "license": "MIT",
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@types/node": "^25.5.0",
    "pkg-pr-new": "^0.0.62",
    "prettier": "^3.7.4",
    "tsdown": "^0.18.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wim-web/mcp-oauth-provider"
  }
}
